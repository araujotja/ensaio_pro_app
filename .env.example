# Supabase — Project URL and anon key (safe to be public)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — Service role key (NEVER expose client-side)
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — API key for AI task generation (server-side only)
ANTHROPIC_API_KEY=

# Public URL of the deployed app — used in invite email links.
# REQUIRED in production: if missing, invite links will point to localhost.
# Example: https://ensaio-pro.vercel.app
NEXT_PUBLIC_APP_URL=

# Signed URL TTL for Storage files in seconds (default: 180)
SIGNED_URL_TTL_SECONDS=180
